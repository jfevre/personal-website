---
// API endpoint via CloudFront proxy
// POST records visit + returns counts (CloudFront-Viewer-Country header added server-side)
// GET returns counts without recording
---

<section id="visitors">
  <h2 class="section-heading fade-up" data-number="05.">Visitor Map</h2>

  <div class="visitors-content fade-up">
    <div class="stats-panel">
      <div class="stat">
        <div class="stat-value" id="total-visitors">-</div>
        <div class="stat-label">Total Visitors</div>
      </div>
      <div class="stat">
        <div class="stat-value" id="top-country">-</div>
        <div class="stat-label">Top Country</div>
      </div>
      <div class="stat">
        <div class="stat-value" id="country-count">-</div>
        <div class="stat-label">Countries</div>
      </div>
    </div>

    <div id="map" class="map-container"></div>
    <div id="map-loading" class="map-loading">Loading visitor data...</div>
    <div id="map-error" class="map-error" style="display: none;">
      Unable to load visitor data. Using demo data.
    </div>
  </div>
</section>

<style>
  #visitors {
    position: relative;
  }

  .visitors-content {
    display: flex;
    flex-direction: column;
    gap: 30px;
  }

  .stats-panel {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-bottom: 10px;
  }

  .stat {
    background: var(--color-navy-light);
    padding: 20px;
    border-radius: var(--border-radius);
    text-align: center;
    border: 1px solid var(--color-slate-dark);
    transition: var(--transition);
  }

  .stat:hover {
    border-color: var(--color-accent);
    transform: translateY(-2px);
  }

  .stat-value {
    font-size: clamp(24px, 4vw, 32px);
    font-weight: 600;
    color: var(--color-accent);
    font-family: var(--font-mono);
    margin-bottom: 8px;
  }

  .stat-label {
    font-size: 14px;
    color: var(--color-slate);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .map-container {
    width: 100%;
    height: 600px;
    border-radius: var(--border-radius);
    overflow: hidden;
    border: 1px solid var(--color-slate-dark);
    position: relative;
    z-index: 1;
  }

  .map-loading,
  .map-error {
    text-align: center;
    padding: 40px;
    color: var(--color-slate);
    font-family: var(--font-mono);
    font-size: 14px;
  }

  .map-error {
    color: var(--color-accent);
  }

  @media (max-width: 1080px) {
    .map-container {
      height: 500px;
    }
    .stats-panel {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .map-container {
      height: 400px;
    }
    .stats-panel {
      grid-template-columns: 1fr;
      gap: 15px;
    }
    .stat {
      padding: 15px;
    }
  }
</style>

<script>
  import L from 'leaflet';
  import 'leaflet/dist/leaflet.css';

  // Demo data for testing (will be replaced by API data)
  const demoData = {
    visitors: [
      { country: 'US', count: 450 },
      { country: 'GB', count: 230 },
      { country: 'DE', count: 180 },
      { country: 'FR', count: 165 },
      { country: 'CA', count: 140 },
      { country: 'AU', count: 120 },
      { country: 'JP', count: 95 },
      { country: 'NL', count: 85 },
      { country: 'SE', count: 70 },
      { country: 'BR', count: 65 }
    ],
    total: 1600
  };

  let map: L.Map | null = null;
  let geoJsonLayer: L.GeoJSON | null = null;
  let visitorData: { country: string; count: number }[] = [];
  let maxCount = 0;

  // API endpoint - use full URL for local dev, relative path for production
  const isLocalDev = window.location.hostname === 'localhost' || window.location.hostname === '127.0.0.1';
  const API_ENDPOINT = isLocalDev ? 'https://john.fevre.uk/api/visitors' : '/api/visitors';

  // Validate ISO-2 country code format
  function isValidCountryCode(code: unknown): code is string {
    return typeof code === 'string' && /^[A-Z]{2}$/.test(code);
  }

  // Validate visitor count is a safe number
  function isValidCount(count: unknown): count is number {
    return typeof count === 'number' &&
           Number.isInteger(count) &&
           count >= 0 &&
           count < 10000000;
  }

  // Validate and sanitize visitor data from API
  function validateVisitorData(data: unknown): { visitors: { country: string; count: number }[]; total: number } {
    if (!data || typeof data !== 'object') {
      throw new Error('Invalid data structure');
    }

    const obj = data as Record<string, unknown>;

    if (!Array.isArray(obj.visitors)) {
      throw new Error('Visitors must be an array');
    }

    const validatedVisitors = obj.visitors
      .filter((v): v is { country: string; count: number } => {
        if (!v || typeof v !== 'object') return false;
        const visitor = v as Record<string, unknown>;
        return isValidCountryCode(visitor.country) && isValidCount(visitor.count);
      })
      .slice(0, 200); // Limit to prevent DoS

    const total = isValidCount(obj.total) ? obj.total : validatedVisitors.reduce((sum, v) => sum + v.count, 0);

    return { visitors: validatedVisitors, total };
  }

  // Create safe popup content using DOM methods (prevents XSS)
  function createPopupContent(countryName: string, visitorCount: number): HTMLElement {
    const container = document.createElement('div');
    container.style.fontFamily = 'var(--font-sans)';
    container.style.padding = '5px';

    const countryEl = document.createElement('strong');
    countryEl.textContent = countryName; // Safe - uses textContent
    container.appendChild(countryEl);

    container.appendChild(document.createElement('br'));

    const visitorsText = document.createTextNode('Visitors: ');
    container.appendChild(visitorsText);

    const countSpan = document.createElement('span');
    countSpan.style.color = 'var(--color-accent)';
    countSpan.style.fontWeight = '600';
    countSpan.textContent = visitorCount.toLocaleString();
    container.appendChild(countSpan);

    return container;
  }

  // Initialize map
  function initMap() {
    const mapContainer = document.getElementById('map');
    if (!mapContainer) return;

    map = L.map('map', {
      center: [20, 0],
      zoom: 2,
      minZoom: 2,
      maxZoom: 6,
      zoomControl: true,
      scrollWheelZoom: false
    });

    // Add base tile layer - theme will be applied after
    updateMapTiles();

    // Load GeoJSON and visitor data
    loadData();
  }

  // Update map tiles based on theme
  function updateMapTiles() {
    if (!map) return;

    // Remove existing tile layers
    map.eachLayer((layer) => {
      if (layer instanceof L.TileLayer) {
        map?.removeLayer(layer);
      }
    });

    const theme = document.documentElement.getAttribute('data-theme') || 'dark';

    if (theme === 'dark') {
      L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_nolabels/{z}/{x}/{y}{r}.png', {
        attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors &copy; <a href="https://carto.com/attributions">CARTO</a>',
        subdomains: 'abcd',
        maxZoom: 20
      }).addTo(map);
    } else {
      L.tileLayer('https://{s}.basemaps.cartocdn.com/light_nolabels/{z}/{x}/{y}{r}.png', {
        attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors &copy; <a href="https://carto.com/attributions">CARTO</a>',
        subdomains: 'abcd',
        maxZoom: 20
      }).addTo(map);
    }
  }

  // Fetch visitor data from API with timeout
  // POST records the visit (CloudFront adds country header server-side)
  // GET would fetch counts without recording
  async function fetchVisitorData() {
    const controller = new AbortController();
    const timeoutId = setTimeout(() => controller.abort(), 10000);

    try {
      const response = await fetch(API_ENDPOINT, {
        method: 'POST',
        signal: controller.signal
      });
      clearTimeout(timeoutId);

      if (!response.ok) throw new Error('API request failed');

      const data = await response.json();
      return validateVisitorData(data);
    } catch (error) {
      // Don't expose error details in production
      console.warn('Failed to load visitor data');
      document.getElementById('map-error')!.style.display = 'block';
      return demoData;
    }
  }

  // Load GeoJSON and visitor data
  async function loadData() {
    try {
      document.getElementById('map-loading')!.style.display = 'block';

      // Fetch visitor data and GeoJSON in parallel
      const [data, geoJsonResponse] = await Promise.all([
        fetchVisitorData(),
        fetch('https://raw.githubusercontent.com/datasets/geo-countries/master/data/countries.geojson')
      ]);

      visitorData = data.visitors || [];
      maxCount = Math.max(...visitorData.map(v => v.count), 1);

      // Update stats
      updateStats(data);

      // Load and style GeoJSON
      const geoJson = await geoJsonResponse.json();

      if (map) {
        geoJsonLayer = L.geoJSON(geoJson, {
          style: (feature) => getCountryStyle(feature),
          onEachFeature: (feature, layer) => {
            const countryCode = feature?.properties?.['ISO3166-1-Alpha-2'];

            // Validate country code format (ISO-2)
            if (!isValidCountryCode(countryCode)) return;

            const visitorCount = visitorData.find(v => v.country === countryCode)?.count || 0;

            if (visitorCount > 0) {
              // Use safe DOM methods to prevent XSS
              const countryName = String(feature.properties.name || 'Unknown');
              layer.bindPopup(createPopupContent(countryName, visitorCount));
            }
          }
        }).addTo(map);
      }

      document.getElementById('map-loading')!.style.display = 'none';
    } catch (error) {
      // Don't expose error details in production
      console.warn('Failed to load map data');
      document.getElementById('map-loading')!.style.display = 'none';
      document.getElementById('map-error')!.style.display = 'block';
    }
  }

  // Get color for country based on visitor count
  function getCountryColor(count: number): string {
    if (count === 0) return 'transparent';

    const theme = document.documentElement.getAttribute('data-theme') || 'dark';
    const intensity = Math.min(count / maxCount, 1);

    if (theme === 'dark') {
      // Orange gradient for dark mode
      const r = 255;
      const g = Math.floor(107 + (255 - 107) * (1 - intensity));
      const b = Math.floor(53 + (200 - 53) * (1 - intensity));
      return `rgb(${r}, ${g}, ${b})`;
    } else {
      // Green gradient for light mode
      const r = Math.floor(31 + (150 - 31) * (1 - intensity));
      const g = Math.floor(95 + (200 - 95) * (1 - intensity));
      const b = Math.floor(31 + (150 - 31) * (1 - intensity));
      return `rgb(${r}, ${g}, ${b})`;
    }
  }

  // Get style for country feature
  function getCountryStyle(feature: any): L.PathOptions {
    const countryCode = feature?.properties?.['ISO3166-1-Alpha-2'];

    // Validate country code before using
    if (!isValidCountryCode(countryCode)) {
      return { fillOpacity: 0, opacity: 0.3, color: '#444', weight: 0.5 };
    }

    const count = visitorData.find(v => v.country === countryCode)?.count || 0;

    return {
      fillColor: getCountryColor(count),
      fillOpacity: count > 0 ? 0.7 : 0,
      color: count > 0 ? '#fff' : '#444',
      weight: count > 0 ? 1 : 0.5,
      opacity: count > 0 ? 0.8 : 0.3
    };
  }

  // Update statistics panel
  function updateStats(data: any) {
    document.getElementById('total-visitors')!.textContent = data.total?.toLocaleString() || '0';
    document.getElementById('country-count')!.textContent = data.visitors?.length?.toString() || '0';

    if (data.visitors && data.visitors.length > 0) {
      const topCountry = data.visitors[0];
      // Try to get country name from code (simplified - could use a lookup table)
      document.getElementById('top-country')!.textContent = topCountry.country || '-';
    }
  }

  // Update map theme
  function updateMapTheme() {
    updateMapTiles();
    if (geoJsonLayer && map) {
      geoJsonLayer.eachLayer((layer: any) => {
        if (layer.feature) {
          layer.setStyle(getCountryStyle(layer.feature));
        }
      });
    }
  }

  // Watch for theme changes
  const observer = new MutationObserver(() => {
    updateMapTheme();
  });

  // Initialize when DOM is ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => {
      initMap();
      observer.observe(document.documentElement, {
        attributes: true,
        attributeFilter: ['data-theme']
      });
    });
  } else {
    initMap();
    observer.observe(document.documentElement, {
      attributes: true,
      attributeFilter: ['data-theme']
    });
  }
</script>
