---
import jobs from '../../content/jobs.json';
---

<section id="experience">
  <h2 class="section-heading fade-up" data-number="02.">Where I've Worked</h2>

  <!-- Desktop: tab UI -->
  <div class="experience-container fade-up">
    <ul class="tab-list" role="tablist">
      {jobs.map((job, i) => (
        <li role="presentation">
          <button
            role="tab"
            class={`tab-btn ${i === 0 ? 'active' : ''}`}
            data-tab={i}
            aria-selected={i === 0 ? 'true' : 'false'}
          >
            {job.company}
          </button>
        </li>
      ))}
    </ul>
    <div class="tab-panels">
      {jobs.map((job, i) => (
        <div role="tabpanel" class={`tab-panel ${i === 0 ? 'active' : ''}`} data-panel={i}>
          <h3 class="job-title">
            {job.role} <span class="at">@</span>
            {job.url
              ? <a href={job.url} target="_blank" rel="noreferrer" class="company-link">{job.company}</a>
              : <span class="company-link">{job.company}</span>
            }
          </h3>
          <p class="job-range">{job.range}</p>
          <ul class="job-bullets">
            {job.bullets.map(bullet => <li>{bullet}</li>)}
          </ul>
        </div>
      ))}
    </div>
  </div>

  <!-- Mobile: vertical card list -->
  <ul class="mobile-list">
    {jobs.map((job, i) => (
      <li class={`mobile-card slide-in ${i % 2 === 0 ? 'from-left' : 'from-right'}`}>
        <p class="job-range">{job.range}</p>
        <h3 class="job-title">
          {job.role} <span class="at">@</span>
          {job.url
            ? <a href={job.url} target="_blank" rel="noreferrer" class="company-link">{job.company}</a>
            : <span class="company-link">{job.company}</span>
          }
        </h3>
        <ul class="job-bullets">
          {job.bullets.map(bullet => <li>{bullet}</li>)}
        </ul>
      </li>
    ))}
  </ul>
</section>

<script>
  // Desktop tab switching
  const tabs = document.querySelectorAll('.tab-btn');

  function animateBullets(panel: Element) {
    const bullets = panel.querySelectorAll('.job-bullets li');
    bullets.forEach((li, i) => {
      setTimeout(() => li.classList.add('bullet-visible'), i * 60);
    });
  }

  const firstPanel = document.querySelector('.tab-panel.active');
  if (firstPanel) {
    firstPanel.classList.add('visible');
    animateBullets(firstPanel);
  }

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      const rawIndex = tab.getAttribute('data-tab');
      const panelIndex = parseInt(rawIndex || '', 10);
      if (isNaN(panelIndex) || panelIndex < 0 || panelIndex > 100) return;

      const current = document.querySelector('.tab-panel.active');
      const next = document.querySelector(`[data-panel="${panelIndex}"]`);
      if (!next || next === current) return;

      tabs.forEach(t => { t.classList.remove('active'); t.setAttribute('aria-selected', 'false'); });
      tab.classList.add('active');
      tab.setAttribute('aria-selected', 'true');

      if (current) {
        current.classList.remove('visible');
        current.querySelectorAll('.job-bullets li').forEach(li => li.classList.remove('bullet-visible'));
        setTimeout(() => {
          current.classList.remove('active');
          next.classList.add('active');
          void (next as HTMLElement).offsetHeight;
          next.classList.add('visible');
          animateBullets(next);
        }, 200);
      } else {
        next.classList.add('active');
        void (next as HTMLElement).offsetHeight;
        next.classList.add('visible');
        animateBullets(next);
      }
    });
  });

  // Mobile slide-in observer
  const slideObserver = new IntersectionObserver(
    (entries) => entries.forEach(e => {
      if (e.isIntersecting) {
        e.target.classList.add('visible');
        slideObserver.unobserve(e.target);
      }
    }),
    { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
  );
  document.querySelectorAll('.mobile-card').forEach(el => slideObserver.observe(el));
</script>

<style>
  #experience {
    justify-content: flex-start;
    padding-top: calc(var(--nav-height) + 80px);
  }

  /* Desktop tab layout */
  .experience-container {
    display: flex;
    gap: 10px;
    max-width: 800px;
    align-items: flex-start;
  }
  .tab-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    min-width: 100px;
    border-left: 2px solid var(--color-slate-dark);
    flex-shrink: 0;
  }
  .tab-btn {
    background: none;
    border: none;
    border-left: 2px solid transparent;
    margin-left: -2px;
    padding: 10px 20px;
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--color-slate);
    cursor: pointer;
    text-align: left;
    white-space: nowrap;
    transition: var(--transition);
  }
  .tab-btn:hover, .tab-btn.active {
    color: var(--color-accent);
    background: var(--color-navy-light);
    border-left-color: var(--color-accent);
  }
  .tab-panels { flex: 1; min-height: 350px; }
  .tab-panel {
    display: none;
    padding: 5px 30px;
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 0.2s ease, transform 0.2s ease;
  }
  .tab-panel.active { display: block; }
  .tab-panel.visible { opacity: 1; transform: translateY(0); }

  /* Shared job content styles */
  .job-title {
    font-size: 20px;
    font-weight: 500;
    color: var(--color-white);
    margin-bottom: 5px;
  }
  .at { color: var(--color-accent); margin: 0 2px; }
  .company-link { color: var(--color-accent); text-decoration: none; }
  .company-link:hover { text-decoration: underline; }
  .job-range {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--color-slate);
    margin-bottom: 12px;
  }
  .job-bullets {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .job-bullets li {
    opacity: 0;
    transform: translateX(-20px);
    transition: opacity 0.3s ease, transform 0.3s ease;
  }
  .job-bullets li.bullet-visible { opacity: 1; transform: translateX(0); }
  .job-bullets li::before { content: '● '; color: var(--color-accent); }

  /* Mobile card list — hidden on desktop */
  .mobile-list { display: none; }

  @media (max-width: 600px) {
    #experience {
      padding-top: calc(var(--nav-height) + 40px);
      padding-bottom: 60px;
    }
    .experience-container { display: none; }
    .mobile-list {
      display: flex;
      flex-direction: column;
      gap: 30px;
      list-style: none;
      overflow: hidden;
    }
    .mobile-card {
      background: var(--color-navy-light);
      border-radius: var(--border-radius);
      padding: 24px;
      border-left: 2px solid var(--color-accent);
      opacity: 0;
      transition: opacity 0.5s ease, transform 0.5s ease;
    }
    .mobile-card.from-left  { transform: translateX(-40px); }
    .mobile-card.from-right { transform: translateX(40px); }
    .mobile-card.visible    { opacity: 1; transform: translateX(0); }
    .mobile-card .job-bullets li {
      opacity: 1;
      transform: none;
    }
  }
</style>
