---
import jobs from '../../content/jobs.json';
---

<section id="experience">
  <h2 class="section-heading fade-up" data-number="02.">Where I've Worked</h2>

  <div class="experience-container fade-up">
    <!-- Tab buttons (populated by JS) -->
    <ul class="tab-list" role="tablist">
      {jobs.map((job, i) => (
        <li role="presentation">
          <button
            role="tab"
            class={`tab-btn ${i === 0 ? 'active' : ''}`}
            data-tab={i}
            aria-selected={i === 0 ? 'true' : 'false'}
          >
            {job.company}
          </button>
        </li>
      ))}
    </ul>

    <!-- Tab panels -->
    <div class="tab-panels">
      {jobs.map((job, i) => (
        <div role="tabpanel" class={`tab-panel ${i === 0 ? 'active' : ''}`} data-panel={i}>
          <h3 class="job-title">
            {job.role} <span class="at">@</span>
            <a href={job.url} target="_blank" rel="noreferrer" class="company-link">
              {job.company}
            </a>
          </h3>
          <p class="job-range">{job.range}</p>
          <ul class="job-bullets">
            {job.bullets.map(bullet => <li>{bullet}</li>)}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  const tabs = document.querySelectorAll('.tab-btn');
  const panels = document.querySelectorAll('.tab-panel');

  function animateBullets(panel: Element) {
    const bullets = panel.querySelectorAll('.job-bullets li');
    bullets.forEach((li, i) => {
      setTimeout(() => li.classList.add('bullet-visible'), i * 60);
    });
  }

  // Show initial panel without animation
  const firstPanel = document.querySelector('.tab-panel.active');
  if (firstPanel) {
    firstPanel.classList.add('visible');
    animateBullets(firstPanel);
  }

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      const rawIndex = tab.getAttribute('data-tab');
      const panelIndex = parseInt(rawIndex || '', 10);
      if (isNaN(panelIndex) || panelIndex < 0 || panelIndex > 100) return;

      const current = document.querySelector('.tab-panel.active');
      const next = document.querySelector(`[data-panel="${panelIndex}"]`);
      if (!next || next === current) return;

      // Update tabs
      tabs.forEach(t => { t.classList.remove('active'); t.setAttribute('aria-selected', 'false'); });
      tab.classList.add('active');
      tab.setAttribute('aria-selected', 'true');

      // Fade out current, then swap and fade in next with bullet animation
      if (current) {
        current.classList.remove('visible');
        // Reset bullets on the outgoing panel immediately
        current.querySelectorAll('.job-bullets li').forEach(li => li.classList.remove('bullet-visible'));
        setTimeout(() => {
          current.classList.remove('active');
          next.classList.add('active');
          void (next as HTMLElement).offsetHeight;
          next.classList.add('visible');
          animateBullets(next);
        }, 200);
      } else {
        next.classList.add('active');
        void (next as HTMLElement).offsetHeight;
        next.classList.add('visible');
        animateBullets(next);
      }
    });
  });
</script>

<style>
  #experience {
    justify-content: flex-start;
    padding-top: calc(var(--nav-height) + 80px);
  }
  .experience-container {
    display: flex;
    gap: 10px;
    max-width: 800px;
    align-items: flex-start;
  }
  .tab-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    min-width: 100px;
    border-left: 2px solid var(--color-slate-dark);
    flex-shrink: 0;
  }
  .tab-btn {
    background: none;
    border: none;
    border-left: 2px solid transparent;
    margin-left: -2px;
    padding: 10px 20px;
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--color-slate);
    cursor: pointer;
    text-align: left;
    white-space: nowrap;
    transition: var(--transition);
  }
  .tab-btn:hover, .tab-btn.active {
    color: var(--color-accent);
    background: var(--color-navy-light);
    border-left-color: var(--color-accent);
  }
  .tab-panels {
    flex: 1;
    min-height: 350px;
  }
  .tab-panel {
    display: none;
    padding: 5px 30px;
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 0.2s ease, transform 0.2s ease;
  }
  .tab-panel.active {
    display: block;
  }
  .tab-panel.visible {
    opacity: 1;
    transform: translateY(0);
  }
  .job-title {
    font-size: 20px;
    font-weight: 500;
    color: var(--color-white);
    margin-bottom: 5px;
  }
  .at { color: var(--color-accent); margin: 0 2px; }
  .company-link { color: var(--color-accent); text-decoration: none; }
  .company-link:hover { text-decoration: underline; }
  .job-range {
    font-family: var(--font-mono);
    font-size: 13px;
    margin-bottom: 20px;
  }
  .job-bullets {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .job-bullets li {
    opacity: 0;
    transform: translateX(-20px);
    transition: opacity 0.3s ease, transform 0.3s ease;
  }
  .job-bullets li.bullet-visible {
    opacity: 1;
    transform: translateX(0);
  }
  .job-bullets li::before {
    content: '● ';
    color: var(--color-accent);
  }

  @media (max-width: 600px) {
    .experience-container { flex-direction: column; }
    .tab-list { flex-direction: row; overflow-x: auto; border-left: none; border-bottom: 2px solid var(--color-slate-dark); }
    .tab-btn { border-left: none; border-bottom: 2px solid transparent; margin-left: 0; margin-bottom: -2px; }
    .tab-btn:hover, .tab-btn.active { border-left-color: transparent; border-bottom-color: var(--color-accent); }
  }
</style>
