---
import meta from '../../content/meta.json';
---

<!-- Fixed left: social icon links -->
<div class="sidebar sidebar--left">
  <ul>
    {meta.social.github && (
      <li>
        <a href={meta.social.github} aria-label="GitHub" target="_blank" rel="noreferrer">
          <!-- Replace text with SVG icon -->
          GH
        </a>
      </li>
    )}
    {meta.social.linkedin && (
      <li>
        <a href={meta.social.linkedin} aria-label="LinkedIn" target="_blank" rel="noreferrer">
          LI
        </a>
      </li>
    )}
    {meta.social.twitter && (
      <li>
        <a href={meta.social.twitter} aria-label="Twitter" target="_blank" rel="noreferrer">
          TW
        </a>
      </li>
    )}
  </ul>
</div>

<!-- Fixed right: email vertical -->
<div class="sidebar sidebar--right">
  <a href={`mailto:${meta.email}`} class="email-link">{meta.email}</a>
</div>

<style>
  .sidebar {
    position: fixed;
    bottom: 0;
    z-index: 10;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
  }
  .sidebar::after {
    content: '';
    display: block;
    width: 1px;
    height: 90px;
    background: var(--color-slate);
  }
  .sidebar--left  { left: 40px; }
  .sidebar--right { right: 40px; }

  .sidebar--left ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .sidebar--left a {
    color: var(--color-slate);
    font-family: var(--font-mono);
    font-size: 12px;
    text-decoration: none;
    transition: var(--transition);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .sidebar--left a:hover {
    color: var(--color-accent);
    transform: translateY(-3px);
  }
  .email-link {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--color-slate);
    letter-spacing: 0.1em;
    writing-mode: vertical-rl;
    text-decoration: none;
    transition: var(--transition);
  }
  .email-link:hover {
    color: var(--color-accent);
    transform: translateY(-3px);
  }

  @media (max-width: 1080px) { .sidebar { display: none; } }
</style>
